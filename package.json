{
  "name": "gnv-onboard-app",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "dependencies": {
    "@sentry/react": "^8.55.0",
    "axios": "^1.6.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^11.0.0",
    "hls.js": "^1.6.15",
    "idb": "^8.0.3",
    "lucide-react": "^0.378.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.30.3",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.4.0",
    "web-vitals": "^5.1.0"
  },
  "scripts": {
    "analyze": "node scripts/analyze-and-sync.cjs --sync-db",
    "cleanup:report": "node scripts/cleanup-unused-files.cjs --report cleanup-report.json",
    "cleanup:dry-run": "node scripts/cleanup-unused-files.cjs",
    "cleanup:delete": "node scripts/cleanup-unused-files.cjs --delete",
    "verify": "node scripts/verify-backend.cjs http://localhost:3000",
    "verify:tablet": "node scripts/verify-tablet-categories.cjs http://localhost:5173",
    "dev": "vite",
    "dev:backend": "cd backend && npm run dev",
    "dev:all": "concurrently -n front,back \"npm run dev\" \"npm run dev:backend\"",
    "dev:tunnel": "node scripts/tunnels/start-tunnel.js",
    "tunnel": "node scripts/tunnels/start-tunnel.js",
    "tunnel:secure": "node scripts/tunnels/start-tunnel-secure.js",
    "tunnel:lt": "node scripts/tunnels/start-tunnel-lt.js",
    "tunnel:lt-capture": "node scripts/tunnels/start-tunnel-lt-capture.js",
    "tunnel:cf": "node scripts/tunnels/start-tunnel-cf.js",
    "build": "vite build",
    "build:analyze": "ANALYZE=1 vite build",
    "preview": "vite preview",
    "audit": "npm audit",
    "audit:ci": "npm audit --audit-level=moderate",
    "test": "vitest run",
    "test:dashboard": "npm test --prefix dashboard",
    "test:bench": "vitest bench --run",
    "test:bench:watch": "vitest bench",
    "test:bench:backend": "npm run bench --prefix backend",
    "profile:backend:cpu": "npm run profile:cpu --prefix backend",
    "profile:backend:heap": "npm run profile:heap --prefix backend",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:mobile": "playwright test --project=mobile-chrome",
    "prepare": "husky",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p backend/tsconfig.json && tsc --noEmit -p dashboard/tsconfig.json",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .js,.jsx",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .js,.jsx --fix",
    "lint:dashboard": "ESLINT_USE_FLAT_CONFIG=false eslint --config dashboard/.eslintrc.cjs dashboard/src --ext .js,.jsx",
    "lint:dashboard:fix": "ESLINT_USE_FLAT_CONFIG=false eslint --config dashboard/.eslintrc.cjs dashboard/src --ext .js,.jsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,md,css}\" \"dashboard/src/**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md,css}\" \"dashboard/src/**/*.{js,jsx,json,css,md}\"",
    "test:load": "k6 run tests/load/k6-load.js",
    "test:load:k6": "k6 run tests/load/gnv-1500-connections.js",
    "test:load:k6:ci": "k6 run --env LOAD_PROFILE=ci tests/load/gnv-1500-connections.js",
    "test:load:api": "k6 run tests/load/gnv-public-api.js",
    "test:load:api:ci": "k6 run --env LOAD_PROFILE=ci tests/load/gnv-public-api.js",
    "test:load:spike": "k6 run tests/load/gnv-spike.js",
    "test:load:spike:ci": "k6 run --env LOAD_PROFILE=ci tests/load/gnv-spike.js",
    "test:load:soak": "k6 run tests/load/gnv-soak.js",
    "test:load:soak:ci": "k6 run --env LOAD_PROFILE=ci tests/load/gnv-soak.js",
    "test:load:artillery": "artillery run -e full tests/load/gnv-1500-connections.yaml",
    "test:load:artillery:ci": "artillery run -e ci tests/load/gnv-1500-connections.yaml",
    "test:load:report": "node scripts/load-test-report.cjs",
    "report:code": "node scripts/code-report.cjs",
    "verify:all": "npm run test:coverage && npm run test:dashboard && npm run typecheck && npm run build && npm run lint && npm run lint:dashboard && npm run format:check && npm run test --prefix backend && npm run lint --prefix backend && npm run format:check --prefix backend && npm run audit:ci && npm run audit:ci --prefix backend",
    "quality": "node scripts/code-quality.cjs",
    "quality:check": "node scripts/code-quality.cjs --check-only",
    "quality:fix": "node scripts/code-quality.cjs --fix-only",
    "devops:gate": "bash scripts/devops-gate.sh --with-tests",
    "devops:gate:quick": "bash scripts/devops-gate.sh --quick",
    "devops:audit": "bash scripts/devops-gate.sh --audit-only",
    "typecheck:backend": "npm run typecheck --prefix backend"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "cross-env ESLINT_USE_FLAT_CONFIG=false eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.js": [
      "cross-env ESLINT_USE_FLAT_CONFIG=false eslint --fix",
      "prettier --write"
    ],
    "dashboard/src/**/*.{js,jsx}": [
      "cross-env ESLINT_USE_FLAT_CONFIG=false eslint --fix --config dashboard/.eslintrc.cjs",
      "prettier --write"
    ],
    "backend/src/**/*.js": [
      "cross-env ESLINT_USE_FLAT_CONFIG=false eslint --fix --config backend/.eslintrc.js",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.0",
    "artillery": "^2.0.30",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^54.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.4.3",
    "ngrok": "^5.0.0-beta.2",
    "playwright": "^1.59.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~5.7.3",
    "vite": "^7.1.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "workbox-window": "^7.4.0"
  }
}
