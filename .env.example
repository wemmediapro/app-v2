# API backend (prod / tunnel). En dev, le proxy Vite utilise /api.
# VITE_API_URL=https://example.com/api

# Socket.io (optionnel, déduit de VITE_API_URL si absent)
# VITE_SOCKET_URL=https://example.com

# Stream vidéo via /uploads : 1 (oui) ou 0 (non)
# VITE_STREAM_VIA_UPLOADS=1

# Backend : rate limit (optionnel)
# RATE_LIMIT_MAX_REQUESTS=10000
# RATE_LIMIT_LOAD_TEST=1   # à 1, relève la limite API pour les tests de charge (k6)
