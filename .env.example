# =============================================================================
# GNV OnBoard — Variables d'environnement FRONTEND (app passagers + dashboard)
# Copiez ce fichier vers .env et adaptez les valeurs à votre environnement.
# Ce fichier est versionné (pas de secrets) — ne jamais mettre de valeurs
# sensibles ici, uniquement des exemples/placeholders.
# =============================================================================

# ----------------------------------------------------------------------------
# API Backend
# Préfixe API versionné (défaut /api/v1). Le backend expose aussi /api/* comme alias.
# VITE_API_PREFIX=/api/v1
# En développement : le proxy Vite (/api → backend) est utilisé automatiquement
#   — VITE_API_URL n'est PAS nécessaire si l'API est sur la même origine.
# Si le port 3000 est déjà pris (ex. autre app Next.js), lancez le backend GNV sur
#   un autre port (voir backend/config.env : PORT=3001) puis définissez :
#   DEV_PROXY_TARGET=http://localhost:3001
# (redémarrer Vite après modification du .env)
# DEV_PROXY_TARGET=http://localhost:3001
# En production ou via tunnel : décommentez et renseignez l'URL réelle.
# ----------------------------------------------------------------------------
# VITE_API_URL=https://travelstream.fr/api

# ----------------------------------------------------------------------------
# Socket.IO
# Optionnel : si absent, déduit automatiquement de VITE_API_URL.
# À définir explicitement uniquement si le serveur Socket.IO est sur un
# domaine/port différent de l'API.
# ----------------------------------------------------------------------------
# VITE_SOCKET_URL=https://travelstream.fr
# Client : reconnexion bornée (défaut activée), timeout poignée de main (ms).
# VITE_SOCKET_RECONNECTION=0
# VITE_SOCKET_RECONNECTION_ATTEMPTS=10
# VITE_SOCKET_TIMEOUT_MS=15000

# ----------------------------------------------------------------------------
# Streaming vidéo/audio
# 1 = les médias sont streamés via /uploads (Nginx direct, recommandé prod)
# 0 = les médias passent par /api/stream (via backend Node.js)
# Valeur recommandée en production : 1
# ----------------------------------------------------------------------------
# VITE_STREAM_VIA_UPLOADS=1

# ----------------------------------------------------------------------------
# Performance / CDN (build)
# VITE_ASSET_BASE : URL ou chemin public des assets (doit finir par /). Ex. :
#   /                          (défaut)
#   https://cdn.example.com/app/
# Dashboard : VITE_DASHBOARD_ASSET_BASE (sinon VITE_ASSET_BASE + défaut /dashboard/)
# ----------------------------------------------------------------------------
# VITE_ASSET_BASE=/
# VITE_DASHBOARD_ASSET_BASE=/dashboard/

# Core Web Vitals → POST /api/v1/metrics/web-vitals (logs serveur). Désactiver :
# VITE_ENABLE_WEB_VITALS=false

# ----------------------------------------------------------------------------
# Sentry (app passager) — erreurs React / ErrorBoundary (optionnel)
# ----------------------------------------------------------------------------
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ----------------------------------------------------------------------------
# Rate Limiting (DEV / tests de charge uniquement)
# ATTENTION : RATE_LIMIT_LOAD_TEST est ignoré automatiquement en production
#   (voir backend/server.js — protection [SEC-6]).
# Ne jamais définir RATE_LIMIT_LOAD_TEST=1 dans un .env de production.
# ----------------------------------------------------------------------------
# RATE_LIMIT_MAX_REQUESTS=2000       # Défaut backend : 2000 req/15 min
# RATE_LIMIT_LOAD_TEST=1             # DEV ONLY — lève la limite pour k6

# ----------------------------------------------------------------------------
# ⚠️  Points d'attention production
# ----------------------------------------------------------------------------
# 1. HTTPS : activer Let's Encrypt sur le serveur :
#      certbot --nginx -d travelstream.fr -d www.travelstream.fr
#
# 2. Mots de passe Docker par défaut à changer dans docker-compose.yml :
#      MONGO_ROOT_PASSWORD=<mot_de_passe_fort>
#      REDIS_PASSWORD=<mot_de_passe_fort>
#    Puis mettre à jour backend/config.env en conséquence :
#      MONGODB_URI=mongodb://admin:<MONGO_PWD>@localhost:27017/gnv_onboard
#      REDIS_URI=redis://:<REDIS_PWD>@localhost:6379
#
# 3. JWT_SECRET dans backend/config.env doit faire ≥ 32 caractères.
#
# 4. FRONTEND_URL dans backend/config.env doit lister TOUTES les origines
#    autorisées (séparées par des virgules) :
#      FRONTEND_URL=https://travelstream.fr,https://www.travelstream.fr
# ----------------------------------------------------------------------------
