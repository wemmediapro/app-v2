# Configuration PRODUCTION — générée par Ansible
# Ne pas commiter les secrets ; utiliser ansible-vault ou --extra-vars

PORT=3000
NODE_ENV=production
CLUSTER_WORKERS=max

MONGODB_URI={{ mongodb_uri }}
DB_NAME=gnv_onboard

REDIS_URI={{ redis_uri }}

JWT_SECRET={{ jwt_secret }}
JWT_EXPIRE=7d

FRONTEND_URL=https://{{ nginx_server_name }},http://{{ nginx_server_name }}

MAX_FILE_SIZE=52428800
UPLOAD_PATH=public/uploads

RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000

ADMIN_EMAIL={{ admin_email | default('admin@gnv.com') }}
ADMIN_PASSWORD={{ admin_password }}

DEMO_MODE=false
FORCE_DEMO=false

SOCKET_MAX_CONNECTIONS=2000
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

NODE_OPTIONS=--max-old-space-size=2048
VIDEO_COMPRESSION_PRESET={{ video_compression_preset | default('veryfast') }}
