# Exemple pour docker compose (copier vers .env à la racine du repo ou sourcer avant `docker compose up`)
# Ne jamais committer de vrais secrets.

MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme
REDIS_PASSWORD=changeme

# Cache WiredTiger (Go) — utile sur petites VM (défaut 0.5 dans compose)
# MONGO_WIRED_TIGER_CACHE_GB=0.5

# Limite mémoire Redis côté serveur (défaut 512mb dans compose)
# REDIS_MAXMEMORY=512mb

# Avec `docker compose --profile app up` : ajouter dans .env (non commité) au minimum
# JWT_SECRET=...  ADMIN_EMAIL=...  ADMIN_PASSWORD=...  FRONTEND_URL=...
# SENTRY_DSN=... (prod)
