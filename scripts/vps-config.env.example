# Configuration pour scripts/update-vps.sh
# Copiez ce fichier en vps-config.env et renseignez les valeurs.
#
# vps-config.env est dans .gitignore (ne pas versionner les accès serveur).

# Connexion SSH (utilisateur@IP ou utilisateur@hostname)
VPS=root@VOTRE_IP

# Répertoire de l'application sur le VPS
APP_DIR=/var/www/gnv-app
