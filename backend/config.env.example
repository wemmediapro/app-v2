# Configuration PRODUCTION pour GNV Backend
# Optimisé pour forte charge (Socket.io + cluster, voir src/socket/socket-scale-metrics.js)
# Copiez ce fichier vers config.env et configurez les valeurs

# Server Configuration
PORT=3000
# Si 3000 est déjà utilisé par un autre projet : PORT=3001
# Puis à la racine du repo (fichier .env) : DEV_PROXY_TARGET=http://localhost:3001
NODE_ENV=production
# Logs JSON (stdout) : info par défaut en prod ; warn pour masquer http_access et bruit démarrage
# LOG_LEVEL=info

# API REST — versionnement : handlers montés sur `/api/v1` et alias `/api` (même code).
# Les frontends utilisent par défaut `VITE_API_PREFIX=/api/v1` (fichier `.env` à la racine du repo, pas ici).

# Clustering
CLUSTER_WORKERS=max
# Ou spécifiez un nombre: CLUSTER_WORKERS=4

# Database — MongoDB (S5 : auth + bind loopback en local). Atlas en prod.
# Local Docker (auth) : MONGODB_URI=mongodb://admin:MONGO_ROOT_PASSWORD@localhost:27017/gnv_onboard
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/gnv_onboard?retryWrites=true&w=majority
# Pool driver (~1500 users / process : défaut max=30 min=10) — voir src/lib/mongoose-connection.js
# MONGODB_MAX_POOL_SIZE=30
# MONGODB_MIN_POOL_SIZE=10
# MONGODB_POOL_MONITOR_INTERVAL_MS=30000
# MONGODB_POOL_ALERT_UTILIZATION=0.9
# MONGODB_POOL_ALERT_COOLDOWN_MS=120000
# MONGODB_CONNECTION_ACQUIRE_WARN_MS=100
# Webhook optionnel (Slack, etc.) si pool ≥ seuil
# MONGODB_POOL_ALERT_WEBHOOK_URL=

# Monitoring des commandes MongoDB (driver) — logs warn si durée ≥ seuil ; 0/false/off pour désactiver
# MONGODB_QUERY_MONITOR=1
# MONGODB_SLOW_QUERY_MS=200
# Plafond de lignes « slow » par minute (0 = ne rien logger)
# MONGODB_SLOW_QUERY_LOG_MAX_PER_MIN=60

# Prometheus (GET /metrics, métriques processus) — activer seulement si accès restreint (VPC, IP internes)
# PROMETHEUS_METRICS_ENABLED=1

# OpenTelemetry (traces + métriques OTLP) — Jaeger / Datadog / Tempo sur 4318
# OTEL_ENABLED=1
# OTEL_SERVICE_NAME=gnv-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_METRIC_EXPORT_INTERVAL_MS=60000

# Files Bull (tâches admin async : audit, e-mail, upload ?async=1, export) — voir src/jobs/
# BULL_JOBS_ENABLED=1
# BULL_JOB_ATTEMPTS=5
# BULL_JOB_BACKOFF_MS=2000
# E-mail sortant (optionnel, pour POST /api/admin/jobs/email)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_SECURE=false

# Audit admin (MongoDB) — index TTL sur le champ timestamp : suppression auto N jours après l’événement.
# Défaut 365 si la variable est absente. 0 = pas d’index TTL (purge via archiveOldLogs / scripts uniquement).
# AUDIT_LOG_TTL_DAYS=365

# Redis (obligatoire en production : Socket.io, rate limit, cache). Sans Redis le serveur refuse de démarrer.
REDIS_URI=redis://localhost:6379
# Cache Redis des réponses GET anonymes (listes publiques) — voir src/middleware/responseCache.js
# RESPONSE_CACHE_ENABLED=1
# RESPONSE_CACHE_DEFAULT_TTL=60
# RESPONSE_CACHE_LOG=1
# Avec mot de passe (docker-compose avec REDIS_PASSWORD) : REDIS_URI=redis://:votre_mot_de_passe_redis@localhost:6379
# Ou pour Redis Cloud: REDIS_URI=redis://user:password@host:port

# Socket.io (scale + CPU) — adapter Redis requis pour PM2 cluster / multi-pods
# SOCKET_MAX_CONNECTIONS=3500
# MAX_CONNECTIONS_PER_IP=50
# SOCKET_CONNECTION_ACCEPT_RATE_PER_SEC=0
# Fenêtre batch même expéditeur/room (0 = désactivé, client : useChat gère __batch)
# SOCKET_BROADCAST_BATCH_MS=0
# Flush dès N messages (défaut 10 si batch activé)
# SOCKET_BROADCAST_BATCH_SIZE=10
# 1 = clés courtes r,c,u,ts sur le fil (client : chatSocketMessages expand)
# SOCKET_MESSAGE_COMPACT=0
# SOCKET_MAX_ROOMS_PER_SOCKET=40
# SOCKET_PING_TIMEOUT_MS=60000
# SOCKET_PING_INTERVAL_MS=25000
# SOCKET_PER_MESSAGE_DEFLATE=0
# SOCKET_MAX_HTTP_BUFFER_SIZE=1000000

# JWT Configuration (production: must be >= 32 characters, load from .env only)
JWT_SECRET=votre-secret-jwt-tres-securise-changez-moi-en-production
JWT_EXPIRE=7d

# CORS Configuration (séparer les URLs par des virgules)
FRONTEND_URL=https://votre-frontend.com,https://www.votre-frontend.com

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_PATH=public/uploads

# Rate Limiting (API) — fenêtre en ms, max requêtes par fenêtre
# Logs structurés JSON (Pino) : niveau global + nom du service (champ `service` sur chaque ligne).
# LOG_LEVEL=info
# LOG_SERVICE_NAME=gnv-backend
# Lecture humaine en local uniquement (dépendance dev `pino-pretty`) ; en prod/staging laisser commenté → JSON stdout.
# LOG_PRETTY=1
# Agrégation : rediriger stdout vers ELK / OpenSearch / Loki / CloudWatch / Datadog (Filebeat, Fluent Bit, agent, etc.).
# Optionnel côté infra : ELASTICSEARCH_URL, index pipeline — pas de transport ES embarqué dans l’app.

# Variables acceptées : RATE_LIMIT_WINDOW ou RATE_LIMIT_WINDOW_MS ; RATE_LIMIT_MAX ou RATE_LIMIT_MAX_REQUESTS
RATE_LIMIT_WINDOW=900000
# Prod : plutôt 200–500 (SPA) — voir config.production.env.example
RATE_LIMIT_MAX=1000

# Admin Configuration — OBLIGATOIRES (aucune valeur par défaut dans l’application)
# Ne jamais utiliser d’identifiants de démo en production (admin@gnv.com est refusé si NODE_ENV=production).
# En production : ADMIN_PASSWORD ≥ 12 caractères et hors liste de mots de passe triviaux (voir src/lib/security-config.js).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# 2FA TOTP (admins) — optionnel
# TWO_FACTOR_ISSUER=GNV OnBoard
# TWO_FACTOR_CHALLENGE_EXPIRES_IN=5m
# TOTP_WINDOW=1

# Demo Mode (false pour production)
DEMO_MODE=false
FORCE_DEMO=false

# Socket.io Configuration
SOCKET_MAX_CONNECTIONS=2000
# Limite par adresse IP (tous workers PM2) via Redis — clés gnv:connections:*
MAX_CONNECTIONS_PER_IP=50
# TTL secondes des clés gnv:connections:* (rafraîchi à chaque écriture, défaut 86400 = 24h)
# GNV_CONNECTIONS_REDIS_TTL_SEC=86400
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000
# Inactivité socket avant cleanup (défaut 3 min) ; sous pression mémoire : 60 s / 30 s (voir connection-manager)
# SOCKET_INACTIVITY_TIMEOUT_MS=180000
# SOCKET_INACTIVITY_AGGRESSIVE_MS=60000
# SOCKET_INACTIVITY_CRITICAL_MS=30000
# SOCKET_CLEANUP_MAX_PER_CYCLE=50

# Surveillance mémoire (heap vs limite V8) — intervalle 30s, seuils 80 / 85 / 90 %
# MEMORY_MONITOR_INTERVAL_MS=30000
# MEMORY_HEAP_ALERT_PERCENT=80
# MEMORY_HEAP_WARNING_PERCENT=85
# MEMORY_HEAP_CRITICAL_PERCENT=90
# Webhook Slack/Discord (POST JSON) — alertes ≥85 % / ≥90 % (throttle 120s par défaut)
# MEMORY_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# MEMORY_ALERT_WEBHOOK_THROTTLE_MS=120000

# Performance
NODE_OPTIONS=--max-old-space-size=2048
UV_THREADPOOL_SIZE=16
# Compression HTTP gzip (zlib) : 4 = plus rapide que 6, fichiers ~5–10 % plus gros (défaut 4)
# COMPRESSION_LEVEL=4
# COMPRESSION_THRESHOLD_BYTES=1024
# Logs structurés event=http_compression_filter_stats (ms) — 0 = désactivé
# COMPRESSION_STATS_INTERVAL_MS=60000
# Rate limit par préfixe d’endpoint (JSON) — remplace les règles par défaut (export, auth, messages, …)
# Export snapshot (GET .../export/snapshot) : quota par utilisateur JWT ou par IP / clé X-Export-Key (défaut 5 / h).
# RATE_LIMIT_EXPORT_SNAPSHOT_MAX=5
# RATE_LIMIT_EXPORT_SNAPSHOT_WINDOW_MS=3600000
# Seuil de log « export volumineux » (approx. nombre d’éléments agrégés) — envisager file async (Bull) au-delà.
# EXPORT_SNAPSHOT_LARGE_THRESHOLD=8000
# RATE_LIMIT_ENDPOINT_RULES_JSON — champs optionnels : windowMs, methods, bucket, keySource (ip|user|auto), windowType (fixed|sliding), adaptive, adaptiveMin
# RATE_LIMIT_ENDPOINT_RULES_JSON=[{"prefix":"/messages","max":10,"windowMs":60000,"methods":["POST"],"keySource":"user","windowType":"sliding"}]
# Limite adaptative (Redis) pour les règles avec "adaptive":true — 1 = actif
# ADAPTIVE_ENDPOINT_RATE_LIMIT=1
# Désactiver la couche par endpoint : 0
# RATE_LIMIT_PER_ENDPOINT=0
# Cache mémoire pour skip rate-limit admin (jwt.verify) — TTL ms, max entrées
# JWT_RATE_LIMIT_SKIP_CACHE_MS=8000
# JWT_RATE_LIMIT_SKIP_CACHE_MAX=3000

# Santé HTTP : 503 sur GET /api/.../health si unhealthy (ou degraded si strict)
# HEALTH_HTTP_STRICT=1
# Seuils checks : ratio heap utilisé / heap total (0–1), espace disque min libre (octets, défaut 1e9)
# HEALTH_HEAP_RATIO_WARN=0.92
# HEALTH_DISK_MIN_FREE_BYTES=1000000000
# Log warn si durée HTTP ≥ N ms (middleware performanceMonitor.js)
# SLOW_HTTP_REQUEST_MS=500
# GET …/metrics/perf (compteurs agrégés) — désactivé par défaut
# PERF_MONITOR_HTTP=1

# Monitoring erreurs — obligatoire en production (validateSecurityConfig ; le serveur ne démarre pas sans DSN HTTPS).
# Créez un projet sur sentry.io et copiez le DSN.
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
