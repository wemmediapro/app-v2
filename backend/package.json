{
  "name": "gnv-backend",
  "version": "1.0.0",
  "description": "Backend API for GNV OnBoard Application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:prod": "UV_THREADPOOL_SIZE=16 NODE_OPTIONS='--max-old-space-size=2048' NODE_ENV=production node server.js",
    "start:cluster": "node cluster.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci",
    "test:coverage": "jest --coverage",
    "bench": "node scripts/run-benchmarks.js",
    "profile:cpu": "node scripts/profile-run.js cpu",
    "profile:heap": "node scripts/profile-run.js heap",
    "dev:inspect": "nodemon --inspect=0.0.0.0:9229 server.js",
    "start:inspect": "node --inspect=0.0.0.0:9229 server.js",
    "openapi:json": "node scripts/export-openapi.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src server.js --ext .js",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint src server.js --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "audit:ci": "npm audit --audit-level=moderate",
    "audit:security-credentials": "node scripts/verify-security-credentials.cjs",
    "init-db": "node scripts/init-database.js",
    "init-db-prisma": "node scripts/init-database-prisma.js",
    "init-admin": "node scripts/init-admin.js",
    "seed:radio": "node scripts/seed-radio.js",
    "seed:magazine-openai": "node scripts/seed-magazine-openai.js",
    "seed:magazine-translations-openai": "node scripts/seed-magazine-translations-openai.js",
    "seed:restaurant-excellent": "node scripts/seed-restaurant-excellent-gnv-openai.js",
    "seed:restaurant-images-openai": "node scripts/seed-restaurant-images-openai.js",
    "seed:shop-images-openai": "node scripts/seed-shop-images-openai.js",
    "seed:shop-products-openai-multilingual": "node scripts/seed-shop-products-openai-multilingual.js",
    "seed:magazine-images-openai": "node scripts/seed-magazine-images-openai.js",
    "seed:articles-maroc-openai": "node scripts/seed-articles-maroc-openai.js",
    "seed:movies-images-openai": "node scripts/seed-movies-images-openai.js",
    "resize:movies-posters": "node scripts/resize-movies-posters.js",
    "compress:images": "node scripts/compress-existing-images.js",
    "compress:images:aggressive": "node scripts/compress-existing-images.js --aggressive",
    "update:image-refs-jpg": "node scripts/update-image-refs-to-jpg.js",
    "seed:restaurant-excellence-multilingual": "node scripts/seed-restaurant-bateau-excellence-multilingual.js",
    "seed:restaurant-excellence-openai-all": "node scripts/seed-restaurant-excellence-openai-all.js",
    "seed:shipmap-excellence": "node scripts/seed-shipmap-excellence-openai.js",
    "seed:shipmap-excellence-multilingual": "node scripts/seed-shipmap-excellence-multilingual.js",
    "seed:ships-gnv": "node scripts/seed-ships-gnv.js",
    "seed:promo-openai-multilingual": "node scripts/seed-promo-openai-multilingual.js",
    "seed:enfant-openai": "node scripts/seed-enfant-openai.js",
    "seed:enfant-images-translations-openai": "node scripts/seed-enfant-images-translations-openai.js",
    "seed:enfant-images-missing": "node scripts/seed-enfant-images-missing.js",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "convert:videos-hls": "node scripts/convert-videos-to-hls.js",
    "analyze:ui": "node scripts/analyze-ui-ergonomics-openai.js",
    "apply:improvements": "node scripts/apply-improvements-openai.js",
    "audit:complet": "node scripts/audit-complet-openia.js",
    "verify:restaurant-images": "node scripts/verify-restaurant-menu-images.js",
    "security:audit": "node scripts/security-audit.js"
  },
  "keywords": [
    "gnv",
    "ferry",
    "onboard",
    "api"
  ],
  "author": "GNV Team",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "^7.0.1",
    "@sentry/node": "^8.55.0",
    "@socket.io/redis-adapter": "^8.2.1",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cheerio": "^1.1.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "file-type": "^21.3.3",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.1.0",
    "isomorphic-dompurify": "^3.7.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^2.0.0",
    "nodemailer": "^8.0.3",
    "openai": "^6.22.0",
    "pino": "^10.3.1",
    "prisma": "^7.0.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "redis": "^4.6.12",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.15",
    "better-sqlite3": "^12.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^54.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.0.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^6.3.3",
    "typescript": "~5.7.3"
  },
  "overrides": {
    "hono": "^4.12.8",
    "@hono/node-server": "^1.19.11",
    "lodash": "^4.17.23",
    "effect": "^3.21.0"
  }
}
