# Environment Variables for GNV Backend

# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/gnv_onboard

# JWT Configuration (production: JWT_SECRET must be >= 32 characters, from .env only, no default)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRE=7d

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=public/uploads

# Rate Limiting (API) — RATE_LIMIT_WINDOW / RATE_LIMIT_MAX (ou RATE_LIMIT_WINDOW_MS / RATE_LIMIT_MAX_REQUESTS)
# ≥ ~2000 recommandé : une page charge plusieurs endpoints ; React 18 en dev double les effets ; notifications en poll.
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=2000
# Tests du rate limit en local : RATE_LIMIT_STRICT_DEV=1 désactive le plancher automatique (voir src/config/index.js)
# En NODE_ENV=development, le rate limit est ignoré pour 127.0.0.1 / ::1 (SPA + Strict Mode). RATE_LIMIT_LOCALHOST=0 pour forcer la limite.

# Admin Configuration — obligatoires pour le login (voir .env.example et SECURITY.md à la racine)
ADMIN_EMAIL=
ADMIN_PASSWORD=



