# Environment Variables for GNV Backend

# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/gnv_onboard

# JWT Configuration (production: JWT_SECRET must be >= 32 characters, from .env only, no default)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRE=7d

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=public/uploads

# Rate Limiting (API) — RATE_LIMIT_WINDOW / RATE_LIMIT_MAX (ou RATE_LIMIT_WINDOW_MS / RATE_LIMIT_MAX_REQUESTS)
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Admin Configuration — obligatoires pour le login (voir .env.example et SECURITY.md à la racine)
ADMIN_EMAIL=
ADMIN_PASSWORD=



