# Ancienne base de données — copiez ce fichier en .env.production et remplissez DATABASE_URL.
# Le backend charge ce fichier après .env et l'utilise en priorité pour la connexion MongoDB.
#
# Remplacez par l'URI réelle de votre cluster (Atlas ou autre) :
DATABASE_URL=mongodb+srv://VOTRE_USER:VOTRE_MOT_DE_PASSE@votre-cluster.xxxxx.mongodb.net/gnv_onboard?retryWrites=true&w=majority
