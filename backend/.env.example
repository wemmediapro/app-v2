# Copier vers .env ou fusionner avec config.env — ne jamais committer de secrets réels.
# Ne jamais utiliser de credentials par défaut (admin@gnv.com, admin123, Admin123!, etc.).

# --- Obligatoires pour le backend et le login admin ---
# Email administrateur (unique, non partagé publiquement)
ADMIN_EMAIL=
# Mot de passe administrateur (min. 8 caractères côté modèle User ; utilisez une phrase forte en prod)
ADMIN_PASSWORD=

# En production : ADMIN_EMAIL / ADMIN_PASSWORD, JWT_SECRET, MongoDB, et SENTRY_DSN (HTTPS) sont exigés au démarrage (validateSecurityConfig).
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# 2FA admin : en production, sans 2FA activé le compte admin est limité à /auth/2fa/setup|verify, /auth/me, /auth/logout.
# ADMIN_2FA_OPTIONAL=1  # déconseillé : désactive ce garde-fou (staging / secours uniquement)
# Liste conversations admin : nombre max de derniers messages analysés pour déduire les paires (défaut 2000, max 50000)
# ADMIN_CONVERSATIONS_MESSAGE_SAMPLE=2000
# En développement, si ADMIN_PASSWORD est vide lors de `npm run init-db`, un mot de passe
# temporaire aléatoire (32 caractères hex) est généré, affiché une seule fois, et
# mustChangePassword=true jusqu’au changement via PUT /api/auth/change-password.

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Logs Pino : trace|debug|info|warn|error|fatal — dev défaut ~debug, prod défaut info (voir logger.js)
# LOG_LEVEL=warn

# Database
MONGODB_URI=mongodb://localhost:27017/gnv_onboard

# JWT (production : >= 32 caractères)
JWT_SECRET=
JWT_EXPIRE=7d

# Rate limiting (optionnel)
# LOGIN_RATE_LIMIT_MAX=5
# API globale (fenêtre 15 min) — prod typique 200–500 ; défaut code sans .env = 2000 (dev relevé à 8000 sur localhost)
# RATE_LIMIT_MAX=400
