# Configuration PRODUCTION pour GNV Backend
# Optimisé pour 2000+ connexions simultanées
# Copiez ce fichier vers config.env et configurez les valeurs

# Server Configuration
PORT=3000
NODE_ENV=production
# Pino : info (défaut) inclut les lignes d’accès HTTP (event http_access) ; warn pour ne garder que warn/error
# LOG_LEVEL=info

# Clustering
CLUSTER_WORKERS=max
# Ou spécifiez un nombre: CLUSTER_WORKERS=4

# Database (MongoDB Atlas recommandé pour production)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/gnv_onboard?retryWrites=true&w=majority
# Requêtes MongoDB lentes (driver) — warn si ≥ ms ; désactiver : MONGODB_QUERY_MONITOR=0
# MONGODB_SLOW_QUERY_MS=300

# Redis (S4 : requirepass). Même mot de passe que REDIS_PASSWORD dans docker-compose.
REDIS_URI=redis://:votre_mot_de_passe_redis@localhost:6379
# Ou pour Redis Cloud: REDIS_URI=redis://user:password@host:port

# Audit admin — TTL MongoDB sur timestamp (jours après l’événement). 0 = désactivé.
# AUDIT_LOG_TTL_DAYS=365

# JWT Configuration (must be >= 32 characters in production)
JWT_SECRET=votre-secret-jwt-tres-securise-changez-moi-en-production
JWT_EXPIRE=7d

# CORS Configuration (séparer les URLs par des virgules)
FRONTEND_URL=https://votre-frontend.com,https://www.votre-frontend.com

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_PATH=public/uploads

# Rate Limiting (API) — fenêtre 15 min par défaut. Une SPA génère beaucoup de GET : 200–500 selon charge ; monter si 429 légitimes.
# Login reste plafonné séparément (LOGIN_RATE_LIMIT_MAX dans auth.js).
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=400

# Admin Configuration — obligatoires ; ne pas utiliser admin@gnv.com (refusé au démarrage et au login)
ADMIN_EMAIL=admin@votre-domaine.tld
ADMIN_PASSWORD=

# Demo Mode (false pour production)
DEMO_MODE=false
FORCE_DEMO=false

# Socket.io Configuration
SOCKET_MAX_CONNECTIONS=2000
# Limite par adresse IP (tous workers PM2) via Redis — clés gnv:connections:*
MAX_CONNECTIONS_PER_IP=50
SOCKET_RATE_LIMIT_MAX=1000
SOCKET_RATE_WINDOW_MS=3600000
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000
# Inactivité socket avant cleanup (défaut 3 min) ; sous pression mémoire : 60 s / 30 s
# SOCKET_INACTIVITY_TIMEOUT_MS=180000
# SOCKET_INACTIVITY_AGGRESSIVE_MS=60000
# SOCKET_INACTIVITY_CRITICAL_MS=30000

# Surveillance mémoire (heap vs limite V8) — intervalle 30s, seuils 80 / 85 / 90 %
# MEMORY_MONITOR_INTERVAL_MS=30000
# MEMORY_HEAP_ALERT_PERCENT=80
# MEMORY_HEAP_WARNING_PERCENT=85
# MEMORY_HEAP_CRITICAL_PERCENT=90
# Webhook Slack/Discord — alertes ≥85 % / ≥90 % (throttle 120s par défaut)
# MEMORY_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# MEMORY_ALERT_WEBHOOK_THROTTLE_MS=120000

# Performance
NODE_OPTIONS=--max-old-space-size=2048
