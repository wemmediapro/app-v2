{
  "name": "gnv-dashboard",
  "version": "1.0.0",
  "description": "Admin Dashboard for GNV OnBoard Application",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tunnel": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "tunnel": "lt --port 5173 --subdomain gnv-dashboard",
    "expose": "npx -y localtunnel --port 5173 --subdomain gnv-dashboard",
    "expose:public": "./expose-frontend.sh",
    "verify-translations": "node scripts/verify-translations.cjs"
  },
  "overrides": {
    "axios": "^1.7.9"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "date-fns": "^2.30.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.577.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.20.1",
    "recharts": "^2.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.16",
    "http-proxy": "^1.18.1",
    "localtunnel": "^2.0.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^7.1.10"
  }
}
