{
  "name": "gnv-dashboard",
  "version": "1.0.0",
  "description": "Admin Dashboard for GNV OnBoard Application",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite",
    "dev:tunnel": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:analyze": "ANALYZE=1 vite build",
    "preview": "vite preview",
    "tunnel": "lt --port 5173 --subdomain gnv-dashboard",
    "expose": "npx -y localtunnel --port 5173 --subdomain gnv-dashboard",
    "expose:public": "./expose-frontend.sh",
    "verify-translations": "node scripts/verify-translations.cjs",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .js,.jsx",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css,md}\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "overrides": {
    "axios": "^1.7.9"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "date-fns": "^2.30.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.378.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.20.1",
    "recharts": "^2.8.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^54.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^25.0.1",
    "http-proxy": "^1.18.1",
    "localtunnel": "^2.0.2",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.7.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.0"
  }
}
